# Source of truth: engines/service_engine/outputs/CURRENT
# These are ephemeral build artifacts — NEVER commit them.
service/services/
service/services_manifest.json

# ── Kubernetes runtime artifacts ──────────────────────
kubeconfig
kubeconfig.yaml
*.kubeconfig
.kube/

# ── Python ────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── IDEs ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.env
